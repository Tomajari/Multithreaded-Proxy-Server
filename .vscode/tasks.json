{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build and Run Proxy Server",
			"type": "shell",
			"command": "g++ -std=c++11 -pthread src/*.cpp -o proxy_server && ./proxy_server",
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "Build and Run Proxy Server (macOS)",
			"type": "shell",
			"command": "g++ -std=c++17 -pthread src/*.cpp -o proxy_server && ./proxy_server",
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		},
		{
			"label": "Rebuild and Run Proxy Server with Debug",
			"type": "shell",
			"command": "g++ -std=c++17 -pthread src/*.cpp -o proxy_server && ./proxy_server",
			"problemMatcher": [
				"$gcc"
			],
			"group": "build"
		}
	]
}